{
  "name": "opencode-pets",
  "version": "1.0.0",
  "description": "Desktop virtual pet for OpenCode coding sessions",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./tui": "./dist/tui.js"
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "@opencode-ai/plugin": "^1.16.2"
  },
  "devDependencies": {
    "@opencode-pets/core": "workspace:*",
    "@opencode-ai/plugin": "^1.16.2",
    "@opentui/core": "^0.4.1",
    "@opentui/keymap": "^0.4.1",
    "@opentui/solid": "^0.4.1"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun --format esm --external @opencode-ai/plugin && bun run scripts/build-tui.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p src/tui/tsconfig.json",
    "prepublishOnly": "bun run build"
  },
  "author": "varoyik",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/varoyik/opencode-pets"
  },
  "keywords": [
    "opencode",
    "pets",
    "virtual-pet"
  ],
  "publishConfig": {
    "access": "public"
  }
}
