{
  "name": "opencode-pets",
  "version": "1.0.2",
  "description": "Desktop pet that reacts to your OpenCode coding sessions in real-time",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./tui": "./dist/tui.js"
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "@opencode-ai/plugin": "^1.16.2"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.16.2",
    "@opencode-pets/core": "workspace:*",
    "@opentui/core": "^0.4.1",
    "@opentui/keymap": "^0.4.1",
    "@opentui/solid": "^0.4.1"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun --format esm --external @opencode-ai/plugin && bun run scripts/build-tui.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p src/tui/tsconfig.json",
    "prepack": "cp ../../README.md README.md",
    "postpack": "rm -f README.md",
    "prepublishOnly": "bun run build"
  },
  "author": "varoyik",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/varoyik/opencode-pets"
  },
  "keywords": [
    "opencode",
    "desktop-pet",
    "virtual-pet",
    "desktop-companion",
    "coding-companion",
    "electron",
    "overlay",
    "electron-overlay",
    "spritesheet",
    "petdex",
    "cross-platform",
    "macos",
    "windows",
    "linux",
    "bun",
    "coding-agent",
    "developer-tools",
    "opencode-plugin"
  ],
  "publishConfig": {
    "access": "public"
  }
}
